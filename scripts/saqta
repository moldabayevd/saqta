#!/usr/bin/env bash
# saqta — красивое меню для saqta.
#
# Требует: gum (brew install gum)
# Опционально: ffprobe (для длительности), osascript (для "открыть в Finder")
#
# Использование:
#   kt                    # интерактивное меню
#   kt transcribe <file>  # прямая команда, обойти меню
#   kt summarize <file>
#   kt full <file>        # transcribe + summarize

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$HOME/.config/saqta/config.sh"
# shellcheck disable=SC1090
[ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"

: "${RECORDINGS_DIR:=$HOME/Recordings}"
: "${SUMMARIZER_MODEL:=qwen3:32b}"
: "${SUMMARIZER_BACKEND:=ollama}"
: "${KK_BACKEND:=qwen3}"

# ─── Цвета / стили ─────────────────────────────────────────────────────────

if ! command -v gum >/dev/null 2>&1; then
    cat << EOF
╔═══════════════════════════════════════════════════════════════╗
║  Для красивого меню нужна утилита gum:                        ║
║                                                               ║
║      brew install gum                                         ║
║                                                               ║
║  Это топ-инструмент от Charm для bash TUI — спиннеры, меню,   ║
║  прогресс-бары. Лёгкая, ~10 МБ.                              ║
║                                                               ║
║  После установки просто запусти kt снова.                     ║
╚═══════════════════════════════════════════════════════════════╝
EOF
    exit 1
fi

C_PRIMARY="212"   # розовый акцент
C_SUCCESS="46"    # зелёный
C_WARN="214"      # оранж
C_MUTED="244"     # серый
C_INFO="39"       # голубой

banner() {
    gum style \
        --border double \
        --border-foreground "$C_PRIMARY" \
        --padding "1 4" \
        --margin "1 0" \
        --align center \
        --bold \
        --foreground "$C_PRIMARY" \
        "🎙️  Saqta" \
        "$(gum style --foreground "$C_MUTED" --italic "приватная транскрипция встреч на Mac")"
}

info()    { gum style --foreground "$C_INFO"    "$@"; }
success() { gum style --foreground "$C_SUCCESS" --bold "$@"; }
warn()    { gum style --foreground "$C_WARN"    "$@"; }
muted()   { gum style --foreground "$C_MUTED"   "$@"; }

# ─── Выбор файла ───────────────────────────────────────────────────────────

pick_file() {
    local prompt="${1:-Выбери файл встречи}"
    local start_dir="${2:-$RECORDINGS_DIR}"

    if [ ! -d "$start_dir" ]; then
        start_dir="$HOME"
    fi

    gum style --foreground "$C_INFO" "$prompt (↑↓ навигация, Enter выбор, Esc отмена)"
    gum file --directory "$start_dir" --file --height 20
}

# ─── Превью файла (имя, размер, длительность) ──────────────────────────────

preview_file() {
    local f="$1"
    local size_h
    size_h=$(du -h "$f" | awk '{print $1}')
    local dur="—"
    if command -v ffprobe >/dev/null 2>&1; then
        local raw
        raw=$(ffprobe -v error -show_entries format=duration \
              -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || echo "")
        if [ -n "$raw" ]; then
            dur=$(awk -v s="$raw" 'BEGIN{h=int(s/3600); m=int((s%3600)/60); printf "%d:%02d", h, m}')
        fi
    fi

    gum style \
        --border rounded \
        --border-foreground "$C_MUTED" \
        --padding "0 2" \
        --margin "0 0" \
        "$(gum style --bold "Файл:") $(basename "$f")" \
        "$(gum style --bold "Размер:") $size_h   $(gum style --bold "Длительность:") $dur"
}

# ─── Операции со спиннерами ────────────────────────────────────────────────

do_transcribe() {
    local file="$1"
    local dir name
    name=$(basename "$file")
    name="${name%.*}"
    dir=$(dirname "$file")
    local out_md="$dir/$name/$name.md"

    gum style --foreground "$C_INFO" --bold "→ Транскрибирую..."

    # Запускаем транскрипцию в фоне чтобы обернуть в спиннер
    local logfile
    logfile=$(mktemp)
    (
        "$SCRIPT_DIR/transcribe-auto.sh" "$file" > "$logfile" 2>&1
        echo "$?" > "${logfile}.status"
    ) &
    local pid=$!

    gum spin --spinner dot \
             --title "Определяю язык → выбираю модель → распознаю речь..." \
             --spinner.foreground "$C_PRIMARY" \
             -- bash -c "while kill -0 $pid 2>/dev/null; do sleep 0.5; done"

    wait $pid
    local status
    status=$(cat "${logfile}.status" 2>/dev/null || echo "1")

    if [ "$status" != "0" ]; then
        warn "✗ Транскрипция упала. Лог:"
        tail -20 "$logfile"
        rm -f "$logfile" "${logfile}.status"
        return 1
    fi

    rm -f "$logfile" "${logfile}.status"

    if [ -f "$out_md" ]; then
        success "✓ Транскрипт готов: $out_md"
        echo "$out_md"
    else
        # На случай если .md лежит в другом месте, ищем свежий
        local found
        found=$(find "$dir" -name "*.md" -newer "$file" 2>/dev/null | head -1)
        [ -n "$found" ] && success "✓ Транскрипт: $found" && echo "$found"
    fi
}

do_summarize() {
    local md_file="$1"
    local out_md="${md_file%.md}-summary.md"

    gum style --foreground "$C_INFO" --bold "→ Саммаризую через $SUMMARIZER_BACKEND ($SUMMARIZER_MODEL)..."

    local logfile
    logfile=$(mktemp)
    (
        "$SCRIPT_DIR/summarize.sh" "$md_file" "$out_md" > "$logfile" 2>&1
        echo "$?" > "${logfile}.status"
    ) &
    local pid=$!

    gum spin --spinner points \
             --title "Модель думает над структурой протокола..." \
             --spinner.foreground "$C_PRIMARY" \
             -- bash -c "while kill -0 $pid 2>/dev/null; do sleep 0.5; done"

    wait $pid
    local status
    status=$(cat "${logfile}.status" 2>/dev/null || echo "1")

    if [ "$status" != "0" ]; then
        warn "✗ Саммаризация упала. Лог:"
        tail -20 "$logfile"
        rm -f "$logfile" "${logfile}.status"
        return 1
    fi

    rm -f "$logfile" "${logfile}.status"
    success "✓ Саммари готов: $out_md"
    echo "$out_md"
}

open_in_finder() {
    local f="$1"
    if command -v osascript >/dev/null 2>&1; then
        osascript -e "tell application \"Finder\" to reveal POSIX file \"$f\"" >/dev/null 2>&1
        osascript -e 'tell application "Finder" to activate' >/dev/null 2>&1
    elif command -v explorer.exe >/dev/null 2>&1; then
        explorer.exe "$(dirname "$f")"
    fi
}

post_action_menu() {
    local f="$1"
    echo ""
    local choice
    choice=$(gum choose --cursor.foreground "$C_PRIMARY" \
        "📂 Открыть в Finder" \
        "👀 Показать содержимое" \
        "🔄 В меню" \
        "🚪 Выход")

    case "$choice" in
        *"Finder"*)  open_in_finder "$f"; post_action_menu "$f" ;;
        *"содержимое"*)
            gum pager < "$f"
            post_action_menu "$f" ;;
        *"меню"*)    return 0 ;;
        *"Выход"*)   exit 0 ;;
    esac
}

# ─── Действия меню ─────────────────────────────────────────────────────────

action_transcribe() {
    local file
    file=$(pick_file "Выбери запись (mp4 / m4a / mov / wav)")
    [ -z "$file" ] && return
    [ -f "$file" ] || { warn "✗ Файл не существует: $file"; return; }

    preview_file "$file"
    gum confirm "Транскрибировать?" || return

    local out
    out=$(do_transcribe "$file")
    [ -n "$out" ] && post_action_menu "$out"
}

action_summarize() {
    local file
    file=$(pick_file "Выбери транскрипт (.md)" "$RECORDINGS_DIR")
    [ -z "$file" ] && return
    [ -f "$file" ] || return

    case "$file" in
        *.md) ;;
        *) warn "✗ Нужен .md файл, не $file"; return ;;
    esac

    preview_file "$file"
    info "Бэкенд: $SUMMARIZER_BACKEND ($SUMMARIZER_MODEL)"
    gum confirm "Сделать саммари?" || return

    local out
    out=$(do_summarize "$file")
    [ -n "$out" ] && post_action_menu "$out"
}

action_full() {
    local file
    file=$(pick_file "Выбери запись для полного пайплайна")
    [ -z "$file" ] && return
    [ -f "$file" ] || return

    preview_file "$file"
    muted "Шаг 1: транскрипция → Шаг 2: саммари"
    gum confirm "Запустить полный пайплайн?" || return

    local transcript
    transcript=$(do_transcribe "$file")
    [ -z "$transcript" ] && return

    echo ""
    local summary
    summary=$(do_summarize "$transcript")
    [ -n "$summary" ] && post_action_menu "$summary"
}

action_recordings_list() {
    if [ ! -d "$RECORDINGS_DIR" ]; then
        warn "✗ Папка записей не существует: $RECORDINGS_DIR"
        muted "Создай её или поменяй RECORDINGS_DIR в config.sh"
        sleep 2
        return
    fi

    # Собираем все аудио/видео файлы в $RECORDINGS_DIR (корень и подпапки
    # первого уровня — чтобы захватить и сырые записи, и созданные папки
    # от transcribe-file.sh).
    local -a recordings=()
    while IFS= read -r f; do
        recordings+=("$f")
    done < <(find "$RECORDINGS_DIR" -maxdepth 2 \
             \( -iname "*.mp4" -o -iname "*.mov" -o -iname "*.m4a" \
                -o -iname "*.wav" -o -iname "*.mp3" \) \
             -type f 2>/dev/null | sort -r)

    if [ ${#recordings[@]} -eq 0 ]; then
        gum style --border rounded --padding "1 2" --border-foreground "$C_WARN" \
            "Записей не найдено в $RECORDINGS_DIR" \
            "" \
            "$(muted "Запиши встречу через QuickRecorder (⌘⇧R)")"
        gum confirm "Открыть папку в Finder?" && open_in_finder "$RECORDINGS_DIR/."
        return
    fi

    # Строим красивые строки меню со статусами
    local -a labels=()
    local -A label_to_file=()
    local f base name parent_dir has_md has_summary status dur date_str time_str size_h

    for f in "${recordings[@]}"; do
        base=$(basename "$f")
        name="${base%.*}"
        parent_dir=$(dirname "$f")

        # Возможные места транскрипта и саммари
        has_md="false"
        has_summary="false"
        if [ -f "$parent_dir/$name/$name.md" ]; then
            has_md="true"
            [ -f "$parent_dir/$name/$name-summary.md" ] && has_summary="true"
        elif [ "$(basename "$parent_dir")" = "$name" ] && [ -f "$parent_dir/$name.md" ]; then
            has_md="true"
            [ -f "$parent_dir/$name-summary.md" ] && has_summary="true"
        fi

        if [ "$has_summary" = "true" ]; then
            status="🟢 summarized"
        elif [ "$has_md" = "true" ]; then
            status="🟡 transcribed"
        else
            status="🔴 raw"
        fi

        # Дата/время из имени файла (QuickRecorder пишет как
        # "Recording at 2026-04-22 16.10.00.mp4") или из mtime
        if [[ "$base" =~ ([0-9]{4}-[0-9]{2}-[0-9]{2})[[:space:]]([0-9]{2})[\.:]([0-9]{2}) ]]; then
            date_str="${BASH_REMATCH[1]}"
            time_str="${BASH_REMATCH[2]}:${BASH_REMATCH[3]}"
        else
            date_str=$(stat -f "%Sm" -t "%Y-%m-%d" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | cut -d' ' -f1)
            time_str=$(stat -f "%Sm" -t "%H:%M" "$f" 2>/dev/null || stat -c "%y" "$f" 2>/dev/null | awk '{print $2}' | cut -d: -f1-2)
        fi

        # Длительность через ffprobe
        dur="—"
        if command -v ffprobe >/dev/null 2>&1; then
            local raw
            raw=$(ffprobe -v error -show_entries format=duration \
                  -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || echo "")
            if [ -n "$raw" ]; then
                dur=$(awk -v s="$raw" 'BEGIN{h=int(s/3600); m=int((s%3600)/60); printf "%d:%02d", h, m}')
            fi
        fi

        size_h=$(du -h "$f" 2>/dev/null | awk '{print $1}')

        # Форматируем строку: дата  время  длительность  размер  статус  имя
        local label
        label=$(printf "%s  %s  %5s  %6s  %-14s  %s" \
                "$date_str" "$time_str" "$dur" "$size_h" "$status" "$name")

        labels+=("$label")
        label_to_file["$label"]="$f"
    done

    gum style --foreground "$C_INFO" --bold "📋 Записи в $RECORDINGS_DIR"
    gum style --foreground "$C_MUTED" \
        "  дата        время  длит.    размер    статус          имя"

    local picked
    picked=$(printf '%s\n' "${labels[@]}" | gum choose \
        --cursor.foreground "$C_PRIMARY" \
        --height 20 \
        --header "↑↓ выбор  •  Enter подтвердить  •  Esc назад")

    [ -z "$picked" ] && return

    local chosen_file="${label_to_file[$picked]}"
    [ -z "$chosen_file" ] || [ ! -f "$chosen_file" ] && return

    # Определяем что уже сделано и что можно запустить
    local base name parent_dir
    base=$(basename "$chosen_file")
    name="${base%.*}"
    parent_dir=$(dirname "$chosen_file")

    local transcript_md=""
    local summary_md=""
    if [ -f "$parent_dir/$name/$name.md" ]; then
        transcript_md="$parent_dir/$name/$name.md"
        [ -f "$parent_dir/$name/$name-summary.md" ] && summary_md="$parent_dir/$name/$name-summary.md"
    elif [ -f "$parent_dir/$name.md" ]; then
        transcript_md="$parent_dir/$name.md"
        [ -f "$parent_dir/$name-summary.md" ] && summary_md="$parent_dir/$name-summary.md"
    fi

    echo ""
    preview_file "$chosen_file"

    # Меню действий — без саммари, только транскрипт + Finder
    local -a actions=()
    if [ -z "$transcript_md" ]; then
        actions+=("🎬 Транскрибировать")
    else
        actions+=("📂 Открыть папку встречи")
        actions+=("📄 Открыть транскрипт (.md)")
        actions+=("🔁 Перетранскрибировать с нуля")
    fi
    actions+=("⬅  Назад к списку")

    local action
    action=$(printf '%s\n' "${actions[@]}" | gum choose --cursor.foreground "$C_PRIMARY")

    case "$action" in
        *"Транскрибировать"*)
            out=$(do_transcribe "$chosen_file")
            [ -n "$out" ] && post_action_menu "$out"
            ;;
        *"Перетранскрибировать"*)
            gum confirm "Удалить старый транскрипт и запустить заново?" || return
            [ -n "$transcript_md" ] && rm -f "$transcript_md"
            out=$(do_transcribe "$chosen_file")
            [ -n "$out" ] && post_action_menu "$out"
            ;;
        *"папку"*)
            open_in_finder "$chosen_file"
            ;;
        *"транскрипт"*)
            [ -n "$transcript_md" ] && open "$transcript_md"
            ;;
        *"Назад"*|"")
            return
            ;;
    esac
}

action_settings() {
    gum style --border rounded --padding "1 2" --border-foreground "$C_INFO" \
        "$(gum style --bold "Настройки (config.sh)")" \
        "" \
        "Recordings:      $RECORDINGS_DIR" \
        "KK_BACKEND:      $KK_BACKEND" \
        "Summarizer:      $SUMMARIZER_BACKEND / $SUMMARIZER_MODEL" \
        "" \
        "$(muted "Правь: $CONFIG_FILE")"

    gum confirm "Открыть config в \$EDITOR?" && "${EDITOR:-nano}" "$CONFIG_FILE"
}

# ─── Главное меню ──────────────────────────────────────────────────────────

main_menu() {
    clear
    banner

    local choice
    choice=$(gum choose \
        --cursor.foreground "$C_PRIMARY" \
        --height 10 \
        "📋  Мои записи (список со статусами)" \
        "🎬  Транскрибировать произвольный файл" \
        "📖  Открыть словарь имён/терминов (prompt.txt)" \
        "⚙️   Настройки" \
        "🚪  Выход")

    case "$choice" in
        *"Мои записи"*)       action_recordings_list ;;
        *"произвольный"*)     action_transcribe ;;
        *"словарь"*)          ${EDITOR:-open} "$HOME/.config/saqta/prompt.txt" ;;
        *"Настройки"*)        action_settings ;;
        *"Выход"*|"")         exit 0 ;;
    esac
}

# ─── CLI режим (обход меню) ────────────────────────────────────────────────

if [ $# -gt 0 ]; then
    cmd="$1"
    shift
    case "$cmd" in
        transcribe) do_transcribe "$1" ;;
        summarize)  do_summarize "$1" ;;
        full)
            tr=$(do_transcribe "$1")
            [ -n "$tr" ] && do_summarize "$tr"
            ;;
        *) echo "Usage: kt [transcribe|summarize|full] <file>" >&2; exit 1 ;;
    esac
    exit 0
fi

# ─── Интерактивный цикл ────────────────────────────────────────────────────

while true; do
    main_menu
    echo ""
done
